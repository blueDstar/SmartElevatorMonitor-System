# SmartElevator Backend Environment Variables
# Copy this file to .env and fill in your actual values

# Flask Configuration
FLASK_HOST=0.0.0.0
FLASK_PORT=10000
FLASK_DEBUG=false
SECRET_KEY=your-secret-key-here
LOG_LEVEL=INFO
JWT_ACCESS_EXP_SECONDS=604800
ALLOW_PUBLIC_REGISTER=false

# CORS Origin (set to your Vercel domain in production)
UI_ORIGIN=https://your-vercel-app.vercel.app

# MongoDB Configuration
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/Elevator_Management?retryWrites=true&w=majority
DATABASE_NAME=Elevator_Management
PERSONNELS_COLLECTION=personnels
EVENTS_COLLECTION=events
ACCOUNT_COLLECTION=account

# Chatbot API Configuration (Choose one provider)
CHATBOT_ENABLED=true
CHAT_API_PROVIDER=huggingface  # or 'openai'
CHAT_API_KEY=your_api_key_here
CHAT_API_MODEL=gpt2  # or 'gpt-3.5-turbo' for OpenAI

# Vision/Camera Configuration
VISION_ENABLED=true
# YOLO / pose on GPU:0 or cpu; legacy alias VISION_DEVICE still works
YOLO_DEVICE=0
POSE_DEVICE=0
# Camera: device index (0) or video file path / rtsp:// URL (Linux/Render)
CAMERA_SOURCE=0
FACE_CTX_ID=0
PREVIEW_ENABLED=false

# Model Paths — place files under backend/model on the server (see backend/model/.gitkeep)
# CHAT_MODEL_PATH=model/Elevator_Assistant.Q4_K_M.gguf
# YOLO_DET_MODEL_PATH=model/yolov8n.pt
# YOLO_POSE_MODEL_PATH=model/yolov8n-pose.pt